          { id: 'sales', name: 'Sales', description: 'Quotations, orders' },
          { id: 'accounting', name: 'Accounting', description: 'Financial management' }
        ]}
      ],
      distribution: [
        { name: 'Essential Apps', modules: [
          { id: 'inventory', name: 'Inventory', description: 'Multi-warehouse, lots, serials' },
          { id: 'sales', name: 'Sales', description: 'Quotations, orders' },
          { id: 'purchase', name: 'Purchase', description: 'Vendor management' },
          { id: 'accounting', name: 'Accounting', description: 'Financial management' }
        ]}
      ],
      restaurant: [
        { name: 'Essential Apps', modules: [
          { id: 'point_of_sale', name: 'Point of Sale', description: 'Restaurant POS' },
          { id: 'inventory', name: 'Inventory', description: 'Stock management' },
          { id: 'purchase', name: 'Purchase', description: 'Procurement' },
          { id: 'accounting', name: 'Accounting', description: 'Financials' }
        ]}
      ],
      healthcare: [
        { name: 'Essential Apps', modules: [
          { id: 'crm', name: 'CRM', description: 'Patient management' },
          { id: 'calendar', name: 'Calendar', description: 'Appointments' },
