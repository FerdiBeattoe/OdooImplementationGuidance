import { el } from '../../../frontend/lib/dom.js';
import { WizardShell } from '../../components/WizardShell.js';

/**
 * WorkcenterWizard - Manufacturing Phase 1
 * 
 * Sets up production work centers, capacity planning, and resource management.
 * 
 * Odoo Sequence: Manufacturing comes AFTER Inventory (needs warehouse context)
 * Odoo Models: mrp.workcenter, resource.calendar, mrp.workcenter.productivity
 */

export class WorkcenterWizard extends WizardShell {
  constructor(options = {}) {
    super({
      title: 'Set Up Your Production Work Centers',
      subtitle: 'Define where manufacturing happens, who operates equipment, and capacity limits',
      icon: 'factory',
      phase: 'manufacturing',
      ...options
    });

    this.phases = [
      { id: 'workcenters', label: 'Work Centers', icon: 'building' },
      { id: 'capacity', label: 'Capacity & Time', icon: 'clock' },
      { id: 'operators', label: 'Operators & Skills', icon: 'users' },
      { id: 'routing', label: 'Default Routings', icon: 'route' },
      { id: 'review', label: 'Review & Apply', icon: 'check' }
    ];
  }

  renderWorkcentersPhase() {
    return el('div', { className: 'wizard-phase' }, [
      el('h3', { text: 'Where do you manufacture?' }),
      el('p', { className: 'help-text', text: 'Work centers are locations where production happens. Examples: Assembly Line, Paint Shop, CNC Area, Packaging Station.' }),
      
      this.renderQuickTemplates([
        { id: 'assembly', label: 'Assembly Line', description: 'General product assembly', tags: ['default'] },
        { id: 'machining', label: 'Machining Center', description: 'CNC, lathe, milling operations', tags: ['metal', 'custom'] },
        { id: 'fabrication', label: 'Fabrication', description: 'Cutting, welding, forming', tags: ['metal', 'custom'] },
        { id: 'finishing', label: 'Finishing/Paint', description: 'Surface treatment, coating', tags: ['default'] },
        { id: 'packaging', label: 'Packaging', description: 'Final packaging and labeling', tags: ['default'] },
        { id: 'quality_lab', label: 'Quality Lab', description: 'Testing and inspection', tags: ['qa'] }
      ]),

      el('div', { className: 'form-section' }, [
        el('h4', { text: 'Work Center Details' }),
        this.formField('workcenter_code', 'Work Center Code', 'text', { placeholder: 'e.g., WC-001, ASSEMBLY-01' }),
        this.formField('workcenter_name', 'Work Center Name', 'text', { placeholder: 'e.g., Main Assembly Line' }),
        this.formSelect('workcenter_type', 'Type', [
          { value: 'assembly', label: 'Assembly' },
          { value: 'machining', label: 'Machining' },
          { value: 'fabrication', label: 'Fabrication' },
          { value: 'finishing', label: 'Finishing' },
          { value: 'packaging', label: 'Packaging' },
          { value: 'testing', label: 'Testing/QA' },
          { value: 'other', label: 'Other' }
        ]),
        this.formSelect('linked_warehouse', 'Linked Warehouse', [], { 
          helpText: 'Which warehouse supplies materials to this work center?',
          dynamicOptions: 'warehouses' // Populated from Odoo
        }),
        this.formField('cost_hour', 'Cost per Hour', 'number', { 
          placeholder: '0.00',
          helpText: 'Operating cost per hour (for costing calculations)'
        })
      ]),

      el('div', { className: 'info-box' }, [
        el('strong', { text: 'Why this matters:' }),
        el('p', { text: 'Work centers determine where capacity constraints exist, how production orders flow, and what resources are needed. Getting this right prevents bottlenecks.' })
      ]),

      this.renderWizardActions(['Back', 'Next'])
    ]);
  }

  renderCapacityPhase() {
    return el('div', { className: 'wizard-phase' }, [
      el('h3', { text: 'When is production happening?' }),
      el('p', { className: 'help-text', text: 'Define operating hours, shifts, and capacity limits for planning.' }),

      el('div', { className: 'form-section' }, [
        el('h4', { text: 'Operating Calendar' }),
        this.formSelect('calendar_type', 'Working Hours', [
          { value: 'standard_40', label: 'Standard 40-hour week (Mon-Fri, 9-5)' },
          { value: 'extended_50', label: 'Extended 50-hour week (Mon-Sat)' },
          { value: 'shifts_24_5', label: '24/5 Shifts (Mon-Fri, 3 shifts)' },
          { value: 'shifts_24_7', label: '24/7 Continuous (3 shifts, 7 days)' },
          { value: 'custom', label: 'Custom schedule (define manually)' }
        ]),
        this.formField('capacity_per_day', 'Daily Capacity (hours)', 'number', {
          placeholder: '8',
          helpText: 'How many hours of work can this center do per day?'
        }),
        this.formField('efficiency_factor', 'Efficiency Factor (%)', 'number', {
          placeholder: '85',
          helpText: 'Realistic efficiency accounting for breaks, setup, minor stops. 85% is typical.'
        })
      ]),

      el('div', { className: 'form-section' }, [
        el('h4', { text: 'Capacity Limits' }),
        this.formField('max_parallel_orders', 'Max Parallel Orders', 'number', {
          placeholder: '1',
          helpText: 'How many orders can run simultaneously? (1 for single-machine, higher for lines with multiple stations)'
        }),
        this.formField('setup_time_buffer', 'Setup Time Buffer (minutes)', 'number', {
          placeholder: '30',
          helpText: 'Default time between switching products'
        })
      ]),

      el('div', { className: 'info-box warning' }, [
        el('strong', { text: 'Impact on Production Planning:' }),
        el('p', { text: 'These values directly affect MRP calculations and delivery date promises. Underestimating capacity leads to late deliveries; overestimating wastes resources.' })
      ]),

      this.renderWizardActions(['Back', 'Next'])
    ]);
  }

  renderOperatorsPhase() {
    return el('div', { className: 'wizard-phase' }, [
      el('h3', { text: 'Who operates this equipment?' }),
      el('p', { className: 'help-text', text: 'Define operator requirements and skill levels for scheduling.' }),

      el('div', { className: 'form-section' }, [
        el('h4', { text: 'Operator Requirements' }),
        this.formSelect('operator_count', 'Required Operators', [
          { value: '0', label: 'No operator (automated)' },
          { value: '1', label: '1 operator' },
          { value: '2', label: '2 operators' },
          { value: '3_plus', label: '3+ operators' }
        ]),
        this.formMultiSelect('required_skills', 'Required Skills', [
          { value: 'cnc_operation', label: 'CNC Operation' },
          { value: 'welding', label: 'Welding Certification' },
          { value: 'assembly', label: 'Assembly Experience' },
          { value: 'quality_inspection', label: 'Quality Inspection' },
          { value: 'forklift', label: 'Forklift License' },
          { value: 'supervision', label: 'Supervision' }
        ]),
        this.formToggle('skill_validation', 'Require skill validation before scheduling', {
          helpText: 'Only employees with verified skills appear in operator selection'
        })
      ]),

      el('div', { className: 'info-box' }, [
        el('strong', { text: 'Odoo Integration:' }),
        el('p', { text: 'These settings link to the HR/Employee module. When you create work orders, Odoo will suggest operators who have the required skills and are available.' })
      ]),

      this.renderWizardActions(['Back', 'Next'])
    ]);
  }

  renderRoutingPhase() {
    return el('div', { className: 'wizard-phase' }, [
      el('h3', { text: 'Default production routings' }),
      el('p', { className: 'help-text', text: 'Set up standard sequences of operations. These can be customized per product later.' }),

      el('div', { className: 'form-section' }, [
        el('h4', { text: 'Common Routing Templates' }),
        this.renderRoutingTemplate('standard_make', 'Make-to-Stock', [
          { step: 'material_pick', label: 'Material Picking', time: '30 min' },
          { step: 'assembly', label: 'Assembly', time: '2 hrs' },
          { step: 'quality_check', label: 'Quality Check', time: '15 min' },
          { step: 'packaging', label: 'Packaging', time: '30 min' }
        ]),
        this.renderRoutingTemplate('make_to_order', 'Make-to-Order', [
          { step: 'material_pick', label: 'Material Picking', time: '30 min' },
          { step: 'machining', label: 'Machining/Custom', time: '4 hrs' },
          { step: 'assembly', label: 'Assembly', time: '1 hr' },
          { step: 'finishing', label: 'Finishing', time: '2 hrs' },
          { step: 'quality_check', label: 'Quality Check', time: '30 min' },
          { step: 'packaging', label: 'Packaging', time: '30 min' }
        ]),
        this.renderRoutingTemplate('repetitive', 'High-Volume Repetitive', [
          { step: 'auto_feed', label: 'Auto Material Feed', time: '5 min' },
          { step: 'production', label: 'Production Run', time: '8 hrs' },
          { step: 'auto_pack', label: 'Auto Packaging', time: '10 min' }
        ])
      ]),

      el('div', { className: 'info-box' }, [
        el('strong', { text: 'Next Step - Bills of Materials:' }),
        el('p', { text: 'After work centers are set up, you will create Bills of Materials (BOMs) that define what components go into each product and which work centers process them.' })
      ]),

      this.renderWizardActions(['Back', 'Next'])
    ]);
  }

  renderRoutingTemplate(id, name, steps) {
    return el('div', { className: 'routing-template', 'data-template': id }, [
      el('div', { className: 'template-header' }, [
        el('input', { type: 'radio', name: 'routing_template', value: id, id: `routing-${id}` }),
        el('label', { htmlFor: `routing-${id}` }, [
          el('strong', { text: name }),
          el('span', { className: 'step-count', text: `${steps.length} steps` })
        ])
      ]),
      el('div', { className: 'template-steps' }, 
        steps.map((step, idx) => el('div', { className: 'step-row' }, [
          el('span', { className: 'step-num', text: idx + 1 }),
          el('span', { className: 'step-name', text: step.label }),
          el('span', { className: 'step-time', text: step.time })
        ]))
      )
    ]);
  }

  renderReviewPhase() {
    return el('div', { className: 'wizard-phase' }, [
      el('h3', { text: 'Review your work centers' }),
      el('p', { className: 'help-text', text: 'Preview what will be created in Odoo:' }),

      this.renderPreviewPanel('Work Centers', [
        ['Name', this.getField('workcenter_name')],
        ['Code', this.getField('workcenter_code')],
        ['Type', this.getField('workcenter_type')],
        ['Linked Warehouse', this.getField('linked_warehouse')],
        ['Daily Capacity', `${this.getField('capacity_per_day')} hours`],
        ['Efficiency', `${this.getField('efficiency_factor')}%`],
        ['Operators Required', this.getField('operator_count')]
      ]),

      el('div', { className: 'safety-notice' }, [
        el('span', { className: 'safety-icon', text: '🛡️' }),
        el('p', { text: 'Rollback available. All changes can be undone within 24 hours.' })
      ]),

      this.renderWizardActions(['Back', 'Apply Changes'])
    ]);
  }

  async onApply() {
    const rollback = new RollbackEngine({ client: this.odooClient });
    
    try {
      rollback.beginTransaction('Workcenter Setup');

      // Create work center
      const workcenterId = await rollback.execute('mrp.workcenter', 'create', {
        name: this.getField('workcenter_name'),
        code: this.getField('workcenter_code'),
        workcenter_type: this.getField('workcenter_type'),
        default_location_id: this.getField('linked_warehouse'),
        costs_hour: parseFloat(this.getField('cost_hour')),
        capacity: parseFloat(this.getField('capacity_per_day')),
        time_efficiency: parseFloat(this.getField('efficiency_factor')) / 100,
        oee_target: 0.85,
        default_operator_count: parseInt(this.getField('operator_count'))
      });

      // Create resource calendar if custom
      if (this.getField('calendar_type') === 'custom') {
        // Calendar creation logic
      }

      rollback.commit();
      this.showSuccess('Work center created successfully!');
      this.navigateToNextWizard('BomWizard');

    } catch (error) {
      await rollback.rollback();
      this.showError('Failed to create work center: ' + error.message);
    }
  }
}
