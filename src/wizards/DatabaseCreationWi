import { el } from '../../frontend/lib/dom.js';

/**
 * Database Creation Wizard
 * Guides users through creating a new Odoo database (trial, online, or on-premise)
 * Following Odoo's official recommended sequence
 */

export class DatabaseCreationWizard {
  constructor(options = {}) {
    this.options = {
      onComplete: options.onComplete || (() => {}),
      onCancel: options.onCancel || (() => {}),
      ...options
    };
    
    this.currentStep = 0;
    this.data = {
      deploymentType: null, // 'online', 'sh', 'onpremise'
      databaseName: '',
      companyName: '',
      email: '',
      password: '',
      phone: '',
      industry: null,
      language: 'en_US',
      country: null,
      modules: []
    };
    
    this.steps = [
      { id: 'deployment', title: 'Choose Your Odoo Setup', description: 'Select how you want to run Odoo' },
      { id: 'company', title: 'Company Information', description: 'Tell us about your business' },
      { id: 'industry', title: 'Industry Selection', description: 'Choose your industry for tailored setup' },
      { id: 'modules', title: 'Select Modules', description: 'Choose the apps you need' },
      { id: 'confirm', title: 'Review & Create', description: 'Confirm your database settings' }
    ];
  }
  
  render() {
    return el('div', { className: 'wizard-container' }, [
      this.renderProgressBar(),
      this.renderCurrentStep(),
      this.renderNavigation()
    ]);
  }
  
  renderProgressBar() {
    const progress = ((this.currentStep + 1) / this.steps.length) * 100;
    
    return el('div', { className: 'wizard-progress' }, [
      el('div', { className: 'progress-steps' }, 
        this.steps.map((step, index) => 
          el('div', { 
            className: `progress-step ${index === this.currentStep ? 'active' : ''} ${index < this.currentStep ? 'completed' : ''}`
          }, [
            el('div', { className: 'step-number', text: String(index + 1) }),
            el('div', { className: 'step-title', text: step.title })
          ])
        )
      ),
      el('div', { className: 'progress-bar' }, [
        el('div', { 
          className: 'progress-fill',
          style: { width: `${progress}%` }
        })
      ])
    ]);
  }
  
  renderCurrentStep() {
    const step = this.steps[this.currentStep];
    
    return el('div', { className: 'wizard-step' }, [
      el('h2', { text: step.title }),
      el('p', { className: 'step-description', text: step.description }),
      this.renderStepContent(step.id)
    ]);
  }
  
  renderStepContent(stepId) {
    switch(stepId) {
      case 'deployment':
        return this.renderDeploymentStep();
      case 'company':
        return this.renderCompanyStep();
      case 'industry':
        return this.renderIndustryStep();
      case 'modules':
        return this.renderModulesStep();
      case 'confirm':
        return this.renderConfirmStep();
      default:
        return el('div', { text: 'Unknown step' });
    }
  }
  
  renderDeploymentStep() {
    const options = [
      {
        id: 'online',
        title: 'Odoo Online (Cloud)',
        description: 'Start immediately with Odoo\'s cloud hosting. No technical setup required.',
        icon: '☁️',
        features: ['Automatic backups', 'Free SSL', 'Email support', '99.9% uptime'],
        recommended: true
      },
      {
        id: 'sh',
        title: 'Odoo.sh (Developers)',
        description: 'For developers and advanced users who need custom code and testing environments.',
        icon: '🛠️',
        features: ['Git integration', 'Staging environments', 'Custom modules', 'SSH access'],
        recommended: false
      },
      {
        id: 'onpremise',
        title: 'On-Premise / Self-Hosted',
        description: 'Install Odoo on your own servers. Full control over your data.',
        icon: '🏢',
        features: ['Full data control', 'Custom infrastructure', 'No subscription limits', 'Requires IT expertise'],
        recommended: false
      }
    ];
    
    return el('div', { className: 'deployment-options' }, 
      options.map(opt => 
        el('button', {
          className: `deployment-card ${this.data.deploymentType === opt.id ? 'selected' : ''}`,
          onclick: () => this.selectDeployment(opt.id)
        }, [
          el('div', { className: 'card-icon', text: opt.icon }),
          el('h3', { text: opt.title }),
          el('p', { text: opt.description }),
          opt.recommended ? el('span', { className: 'recommended-badge', text: 'Recommended' }) : null,
          el('ul', { className: 'feature-list' }, 
            opt.features.map(f => el('li', { text: `✓ ${f}` }))
          )
        ])
      )
    );
  }
  
  renderCompanyStep() {
    return el('div', { className: 'form-grid' }, [
      this.renderInput('companyName', 'Company Name', 'Your business name', 'text', true),
      this.renderInput('email', 'Email Address', 'admin@yourcompany.com', 'email', true),
      this.renderInput('phone', 'Phone Number', '+27 12 345 6789', 'tel', false),
      this.renderInput('password', 'Admin Password', 'Create a secure password', 'password', true),
      this.renderCountrySelect()
    ]);
  }
  
  renderIndustryStep() {
    const industries = [
      { id: 'retail', name: 'Retail & E-commerce', icon: '🛒', description: 'Shops, online stores, product sales' },
      { id: 'manufacturing', name: 'Manufacturing', icon: '🏭', description: 'Production, BOMs, work orders, quality' },
      { id: 'services', name: 'Professional Services', icon: '💼', description: 'Consulting, agencies, project-based work' },
      { id: 'distribution', name: 'Distribution & Wholesale', icon: '📦', description: 'Inventory management, warehouses, logistics' },
      { id: 'restaurant', name: 'Restaurant & Hospitality', icon: '🍽️', description: 'POS, tables, kitchens, reservations' },
      { id: 'healthcare', name: 'Healthcare', icon: '🏥', description: 'Appointments, patient records, compliance' }
    ];
    
    return el('div', { className: 'industry-grid' },
      industries.map(ind => 
        el('button', {
          className: `industry-card ${this.data.industry === ind.id ? 'selected' : ''}`,
          onclick: () => this.selectIndustry(ind.id)
        }, [
          el('div', { className: 'industry-icon', text: ind.icon }),
          el('h3', { text: ind.name }),
          el('p', { text: ind.description })
        ])
      )
    );
  }
  
  renderModulesStep() {
    const moduleGroups = this.getRecommendedModules();
    
    return el('div', { className: 'modules-container' }, [
      el('p', { className: 'modules-intro', text: `Recommended for ${this.getIndustryName()}. Select the modules you need:` }),
      ...moduleGroups.map(group => 
        el('div', { className: 'module-group' }, [
          el('h3', { text: group.name }),
          el('div', { className: 'module-list' },
            group.modules.map(mod => 
              el('label', { className: 'module-checkbox' }, [
                el('input', {
                  type: 'checkbox',
                  checked: this.data.modules.includes(mod.id),
                  onchange: (e) => this.toggleModule(mod.id, e.target.checked)
                }),
                el('div', { className: 'module-info' }, [
                  el('strong', { text: mod.name }),
                  el('span', { text: mod.description })
                ])
              ])
            )
          )
        ])
      )
    ]);
  }
  
  renderConfirmStep() {
    return el('div', { className: 'confirm-container' }, [
      el('h3', { text: 'Review Your Database Settings' }),
      this.renderSummaryItem('Deployment', this.getDeploymentName()),
      this.renderSummaryItem('Company', this.data.companyName),
      this.renderSummaryItem('Email', this.data.email),
      this.renderSummaryItem('Industry', this.getIndustryName()),
      this.renderSummaryItem('Selected Modules', `${this.data.modules.length} modules`),
      el('div', { className: 'terms-box' }, [
        el('label', {}, [
          el('input', { type: 'checkbox', required: true }),
          el('span', { text: 'I agree to Odoo\'s Terms of Service and Privacy Policy' })
        ])
      ])
    ]);
  }
  
  renderNavigation() {
    return el('div', { className: 'wizard-navigation' }, [
      this.currentStep > 0 
        ? el('button', { 
            className: 'btn-secondary',
            onclick: () => this.previousStep()
          }, '← Back')
        : el('button', { 
            className: 'btn-secondary',
            onclick: () => this.options.onCancel()
          }, 'Cancel'),
      
      this.currentStep < this.steps.length - 1
        ? el('button', { 
            className: 'btn-primary',
            disabled: !this.canProceed(),
            onclick: () => this.nextStep()
          }, 'Next →')
        : el('button', { 
            className: 'btn-primary btn-create',
            disabled: !this.canCreate(),
            onclick: () => this.createDatabase()
          }, 'Create Database')
    ]);
  }
  
  // Helper methods
  renderInput(name, label, placeholder, type, required) {
    return el('div', { className: 'form-field' }, [
      el('label', { text: `${label}${required ? ' *' : ''}` }),
      el('input', {
        type,
        placeholder,
        value: this.data[name] || '',
        required,
        oninput: (e) => this.updateData(name, e.target.value)
      })
    ]);
  }
  
  renderCountrySelect() {
    const countries = [
      { code: 'ZA', name: 'South Africa' },
      { code: 'US', name: 'United States' },
      { code: 'GB', name: 'United Kingdom' },
      { code: 'AU', name: 'Australia' },
      { code: 'CA', name: 'Canada' },
      { code: 'DE', name: 'Germany' },
      { code: 'FR', name: 'France' },
      { code: 'NL', name: 'Netherlands' }
    ];
    
    return el('div', { className: 'form-field' }, [
      el('label', { text: 'Country *' }),
      el('select', {
        value: this.data.country || '',
        onchange: (e) => this.updateData('country', e.target.value)
      }, [
        el('option', { value: '', text: 'Select your country' }),
        ...countries.map(c => el('option', { value: c.code, text: c.name }))
      ])
    ]);
  }
  
  renderSummaryItem(label, value) {
    return el('div', { className: 'summary-row' }, [
      el('span', { className: 'summary-label', text: label }),
      el('span', { className: 'summary-value', text: value || 'Not set' })
    ]);
  }
  
  // State management
  selectDeployment(type) {
    this.data.deploymentType = type;
    this.render();
  }
  
  selectIndustry(industry) {
    this.data.industry = industry;
    this.render();
  }
  
  updateData(field, value) {
    this.data[field] = value;
  }
  
  toggleModule(moduleId, checked) {
    if (checked) {
      this.data.modules = [...this.data.modules, moduleId];
    } else {
      this.data.modules = this.data.modules.filter(m => m !== moduleId);
    }
    this.render();
  }
  
  nextStep() {
    if (this.currentStep < this.steps.length - 1) {
      this.currentStep++;
      this.render();
    }
  }
  
  previousStep() {
    if (this.currentStep > 0) {
      this.currentStep--;
      this.render();
    }
  }
  
  canProceed() {
    const step = this.steps[this.currentStep];
    switch(step.id) {
      case 'deployment':
        return !!this.data.deploymentType;
      case 'company':
        return this.data.companyName && this.data.email && this.data.password;
      case 'industry':
        return !!this.data.industry;
      case 'modules':
        return this.data.modules.length > 0;
      default:
        return true;
    }
  }
  
  canCreate() {
    return this.canProceed() && this.currentStep === this.steps.length - 1;
  }
  
  // Data helpers
  getDeploymentName() {
    const names = { online: 'Odoo Online', sh: 'Odoo.sh', onpremise: 'On-Premise' };
    return names[this.data.deploymentType] || 'Not selected';
  }
  
  getIndustryName() {
    const names = {
      retail: 'Retail & E-commerce',
      manufacturing: 'Manufacturing',
      services: 'Professional Services',
      distribution: 'Distribution & Wholesale',
      restaurant: 'Restaurant & Hospitality',
      healthcare: 'Healthcare'
    };
    return names[this.data.industry] || 'Not selected';
  }
  
