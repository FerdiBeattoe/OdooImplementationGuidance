import { el } from '../../frontend/lib/dom.js';

/**
 * Visual Progress Tracker Component
 * Shows implementation progress with icons, percentages, and phase indicators
 */

export class VisualProgressTracker {
  constructor(options = {}) {
    this.options = {
      phases: options.phases || [],
      currentPhase: options.currentPhase || 0,
      completedSteps: options.completedSteps || [],
      onPhaseClick: options.onPhaseClick || (() => {}),
      ...options
    };
  }
  
  render() {
    return el('div', { className: 'visual-progress-tracker' }, [
      this.renderOverallProgress(),
      this.renderPhaseTimeline(),
      this.renderCompletionStats()
    ]);
  }
  
  renderOverallProgress() {
    const totalSteps = this.options.phases.reduce((sum, p) => sum + p.steps, 0);
    const completed = this.options.completedSteps.length;
    const percentage = Math.round((completed / totalSteps) * 100);
    
    return el('div', { className: 'overall-progress' }, [
      el('div', { className: 'progress-header' }, [
        el('h3', { text: 'Your Odoo Setup Progress' }),
        el('span', { className: 'percentage', text: `${percentage}%` })
      ]),
      el('div', { className: 'progress-bar-container' }, [
        el('div', { 
          className: 'progress-bar-fill',
          style: `width: ${percentage}%`
        }),
        this.options.phases.map((phase, idx) => {
          const phasePos = this.getPhasePosition(idx);
          return el('div', {
            className: `phase-marker ${idx <= this.options.currentPhase ? 'active' : ''}`,
            style: `left: ${phasePos}%`,
            title: phase.name
          });
        })
      ])
    ]);
  }
  
  renderPhaseTimeline() {
    return el('div', { className: 'phase-timeline' },
      this.options.phases.map((phase, idx) => {
        const status = this.getPhaseStatus(idx);
        const isClickable = status === 'available' || status === 'current';
        
        return el('div', {
          className: `phase-card ${status} ${isClickable ? 'clickable' : ''}`,
          onclick: isClickable ? () => this.options.onPhaseClick(idx) : null
        }, [
          el('div', { className: 'phase-icon' }, [
            el('span', { text: phase.icon || this.getDefaultIcon(idx) })
          ]),
          el('div', { className: 'phase-content' }, [
            el('h4', { text: phase.name }),
            el('p', { text: phase.description }),
            this.renderPhaseSteps(phase, idx)
          ]),
          el('div', { className: 'phase-status-badge', text: this.getStatusLabel(status) })
        ]);
      })
    );
  }
  
  renderPhaseSteps(phase, phaseIdx) {
    const stepsInPhase = this.getStepsInPhase(phaseIdx);
    const completedInPhase = stepsInPhase.filter(s => 
      this.options.completedSteps.includes(s.id)
    ).length;
    
    return el('div', { className: 'phase-steps' }, [
      el('span', { 
        text: `${completedInPhase}/${stepsInPhase.length} steps complete`
      }),
      el('div', { className: 'mini-progress' },
        stepsInPhase.map(step => 
          el('div', {
            className: `step-dot ${
              this.options.completedSteps.includes(step.id) ? 'done' : 
              this.options.currentPhase === phaseIdx && step.current ? 'current' : ''
            }`,
            title: step.name
          })
        )
      )
    ]);
  }
  
  renderCompletionStats() {
    const stats = this.calculateStats();
    
    return el('div', { className: 'completion-stats' }, [
      el('div', { className: 'stat-card' }, [
        el('span', { className: 'stat-value', text: String(stats.domainsReady) }),
        el('span', { className: 'stat-label', text: 'Ready to Go Live' })
      ]),
      el('div', { className: 'stat-card' }, [
        el('span', { className: 'stat-value', text: String(stats.pending) }),
        el('span', { className: 'stat-label', text: 'Steps Pending' })
      ]),
      el('div', { className: 'stat-card warning' }, [
        el('span', { className: 'stat-value', text: String(stats.blockers) }),
        el('span', { className: 'stat-label', text: 'Blockers' })
      ]),
      el('div', { className: 'stat-card' }, [
        el('span', { className: 'stat-value', text: stats.timeEstimate }),
        el('span', { className: 'stat-label', text: 'Est. Time Remaining' })
      ])
    ]);
  }
  
  getPhaseStatus(phaseIdx) {
    if (phaseIdx < this.options.currentPhase) return 'completed';
    if (phaseIdx === this.options.currentPhase) return 'current';
    if (phaseIdx === this.options.currentPhase + 1) return 'available';
    return 'locked';
  }
  
  getStatusLabel(status) {
    const labels = {
      completed: '✓ Done',
      current: 'In Progress',
      available: 'Next',
      locked: 'Locked'
    };
    return labels[status] || status;
  }
  
  getDefaultIcon(idx) {
    const icons = ['🚀', '🔧', '👥', '📦', '💰', '⚙️', '📊', '✅'];
    return icons[idx] || '📋';
  }
  
  getPhasePosition(phaseIdx) {
    const totalPhases = this.options.phases.length;
    return (phaseIdx / (totalPhases - 1)) * 100;
  }
  
  getStepsInPhase(phaseIdx) {
    const phase = this.options.phases[phaseIdx];
    if (!phase) return [];
    return phase.steps || [];
  }
  
  calculateStats() {
    const totalSteps = this.options.phases.reduce((sum, p) => sum + (p.steps?.length || 0), 0);
    const completed = this.options.completedSteps.length;
    const pending = totalSteps - completed;
    
    // Count domains that are ready (all critical steps done)
    const domainsReady = this.options.phases.filter(p => {
      const pSteps = p.steps || [];
      const criticalSteps = pSteps.filter(s => s.critical);
      const doneCritical = criticalSteps.filter(s => 
        this.options.completedSteps.includes(s.id)
      ).length;
      return criticalSteps.length > 0 && doneCritical === criticalSteps.length;
    }).length;
    
    // Blockers = steps marked as blocking that aren't done
    const blockers = this.options.phases.reduce((count, p) => {
      const blocking = (p.steps || []).filter(s => s.blocking && !this.options.completedSteps.includes(s.id));
      return count + blocking.length;
    }, 0);
    
    // Time estimate based on pending steps
    const hoursPerStep = 0.5;
    const hoursRemaining = Math.ceil(pending * hoursPerStep);
    const timeEstimate = hoursRemaining < 1 ? '< 1 hour' : 
      hoursRemaining < 8 ? `${hoursRemaining} hours` : 
      `${Math.ceil(hoursRemaining / 8)} days`;
    
    return { domainsReady, pending, blockers, timeEstimate };
  }
}

export default VisualProgressTracker;
