          { id: 'purchase', name: 'Purchase', description: 'Vendor management, procurement' },
          { id: 'accounting', name: 'Accounting', description: 'Financial management' },
          { id: 'mrp', name: 'Manufacturing', description: 'BOMs, work orders, production' }
        ]},
        { name: 'Quality & Planning', modules: [
          { id: 'quality', name: 'Quality', description: 'Quality checks, control points' },
