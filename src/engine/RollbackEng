import { OdooClient } from '../api/OdooClient.js';

/**
 * Rollback Engine
 * Provides transactional safety for Odoo implementation changes
 * Allows undoing configuration changes with full audit trail
 */

export class RollbackEngine {
  constructor(options = {}) {
    this.options = {
      client: options.client || null,
      maxHistory: options.maxHistory || 100,
      ...options
    };
    
    // Transaction log
    this.transactions = [];
    
    // State snapshots before changes
    this.snapshots = new Map();
    
    // Current transaction ID
    this.currentTransaction = null;
  }
  
  /**
   * Start a new transaction
   * All subsequent operations will be grouped for potential rollback
   */
  beginTransaction(description = '') {
    const txId = `tx-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
    
    this.currentTransaction = {
      id: txId,
      description,
      startedAt: new Date().toISOString(),
      operations: [],
      status: 'pending'
    };
    
    return txId;
  }
  
  /**
   * Record a snapshot before making changes
   */
  async snapshot(model, ids, fields = []) {
    if (!this.options.client) {
      throw new Error('No Odoo client available');
    }
    
    const key = `${model}:${ids.join(',')}`;
    
    try {
      const records = await this.options.client.read(model, ids, fields);
      this.snapshots.set(key, {
        model,
        ids,
        records,
        snapshottedAt: new Date().toISOString()
      });
      
      return true;
    } catch (error) {
      console.error('Snapshot failed:', error);
      return false;
    }
  }
  
  /**
   * Execute an operation with rollback protection
   */
  async execute(model, operation, data, options = {}) {
    const tx = this.currentTransaction;
    
    if (!tx) {
      throw new Error('No active transaction. Call beginTransaction() first.');
    }
    
    const opId = `${tx.id}-op${tx.operations.length}`;
    
    try {
      // Snapshot before change (if IDs known)
      if (operation === 'write' && data.ids) {
        await this.snapshot(model, data.ids, Object.keys(data.values));
      }
      
      // Execute the operation
      let result;
      switch (operation) {
        case 'create':
          result = await this.options.client.create(model, data.values);
          break;
        case 'write':
          result = await this.options.client.write(model, data.ids, data.values);
          break;
        case 'unlink':
          result = await this.options.client.unlink(model, data.ids);
          break;
        default:
          throw new Error(`Unknown operation: ${operation}`);
      }
      
      // Record successful operation
      tx.operations.push({
        id: opId,
        model,
        operation,
        data,
        result,
        status: 'success',
        executedAt: new Date().toISOString()
      });
      
      return { success: true, id: opId, result };
      
    } catch (error) {
      // Record failed operation
      tx.operations.push({
        id: opId,
        model,
        operation,
        data,
        error: error.message,
        status: 'failed',
        executedAt: new Date().toISOString()
      });
      
      // Auto-rollback on failure if requested
      if (options.autoRollback) {
        await this.rollback(tx.id);
      }
      
      throw error;
    }
  }
  
  /**
   * Commit the current transaction
   */
  commit(transactionId = null) {
    const tx = transactionId 
      ? this.transactions.find(t => t.id === transactionId)
      : this.currentTransaction;
    
    if (!tx) {
      throw new Error('No transaction to commit');
    }
    
    tx.status = 'committed';
    tx.committedAt = new Date().toISOString();
    
    // Archive transaction
    this.transactions.push(tx);
    
    // Clear current transaction
    if (this.currentTransaction?.id === tx.id) {
      this.currentTransaction = null;
    }
    
    // Cleanup old snapshots
    this.cleanupSnapshots();
    
    return tx;
  }
  
  /**
   * Rollback a transaction - RESTORE PREVIOUS STATE
   */
  async rollback(transactionId = null) {
    const tx = transactionId
      ? this.transactions.find(t => t.id === transactionId) || this.currentTransaction
      : this.currentTransaction;
    
    if (!tx) {
      throw new Error('No transaction to rollback');
    }
    
    const rollbacks = [];
    const failures = [];
    
    // Process operations in reverse order
    for (const op of [...tx.operations].reverse()) {
      try {
        let rollbackResult;
        
        switch (op.operation) {
          case 'create':
            // Delete created records
            rollbackResult = await this.options.client.unlink(op.model, [op.result]);
            break;
            
          case 'write':
            // Restore from snapshot
            const key = `${op.model}:${op.data.ids.join(',')}`;
            const snapshot = this.snapshots.get(key);
            
            if (snapshot) {
              for (const record of snapshot.records) {
                const restoreData = {};
                for (const field of Object.keys(op.data.values)) {
                  if (record[field] !== undefined) {
                    restoreData[field] = record[field];
                  }
                }
                rollbackResult = await this.options.client.write(op.model, [record.id], restoreData);
              }
            }
            break;
            
          case 'unlink':
            // Cannot restore unlinked records without full backup
            rollbackResult = { warning: 'Unlink cannot be undone. Records must be recreated manually.' };
            break;
        }
        
        rollbacks.push({
          operationId: op.id,
          result: rollbackResult,
          timestamp: new Date().toISOString()
        });
        
      } catch (error) {
        failures.push({
          operationId: op.id,
          error: error.message,
          timestamp: new Date().toISOString()
        });
      }
    }
    
    tx.status = 'rolled_back';
    tx.rolledBackAt = new Date().toISOString();
    tx.rollbackResults = { rollbacks, failures };
    
    // Archive if not already
    if (!this.transactions.find(t => t.id === tx.id)) {
      this.transactions.push(tx);
    }
    
    // Clear current transaction
    if (this.currentTransaction?.id === tx.id) {
      this.currentTransaction = null;
    }
    
    return {
      transactionId: tx.id,
      success: failures.length === 0,
      rollbacks,
      failures
    };
  }
  
  /**
   * Get transaction history
   */
  getHistory(filters = {}) {
    let history = [...this.transactions];
    
    if (filters.status) {
      history = history.filter(t => t.status === filters.status);
    }
    
    if (filters.since) {
      history = history.filter(t => new Date(t.startedAt) >= new Date(filters.since));
    }
    
    return history.sort((a, b) => new Date(b.startedAt) - new Date(a.startedAt));
  }
  
  /**
   * Get audit report for a transaction
   */
  getAuditReport(transactionId) {
    const tx = this.transactions.find(t => t.id === transactionId);
    if (!tx) return null;
    
    return {
      id: tx.id,
      description: tx.description,
      status: tx.status,
      startedAt: tx.startedAt,
      completedAt: tx.committedAt || tx.rolledBackAt,
      duration: this.calculateDuration(tx.startedAt, tx.committedAt || tx.rolledBackAt),
      operations: tx.operations.length,
      successfulOps: tx.operations.filter(o => o.status === 'success').length,
      failedOps: tx.operations.filter(o => o.status === 'failed').length,
      rollbackStatus: tx.rollbackResults || null
    };
  }
  
  /**
   * Batch execute multiple operations atomically
   */
  async batchExecute(operations, options = {}) {
    const txId = this.beginTransaction(options.description || 'Batch operation');
    
    try {
      for (const op of operations) {
        await this.execute(op.model, op.operation, op.data, { autoRollback: false });
      }
      
      if (options.dryRun) {
        // Preview only - rollback immediately
        await this.rollback(txId);
        return { 
          transactionId: txId, 
          status: 'preview',
          operations: this.currentTransaction.operations 
        };
      } else {
        this.commit(txId);
        return { 
          transactionId: txId, 
          status: 'committed',
          operations: this.currentTransaction?.operations || [] 
        };
      }
      
    } catch (error) {
      if (options.autoRollback !== false) {
        await this.rollback(txId);
      }
      throw error;
    }
  }
  
  cleanupSnapshots() {
    // Keep only snapshots for recent transactions
    const recentTxIds = new Set(
      this.transactions
        .slice(-10)
        .map(t => t.id)
    );
    
    for (const [key, snapshot] of this.snapshots) {
      const txId = key.split(':')[0];
      if (!recentTxIds.has(txId)) {
        this.snapshots.delete(key);
      }
    }
  }
  
  calculateDuration(start, end) {
    if (!start || !end) return null;
    const ms = new Date(end) - new Date(start);
    return {
      milliseconds: ms,
      seconds: Math.round(ms / 1000 * 100) / 100
    };
  }
}

export default RollbackEngine;
