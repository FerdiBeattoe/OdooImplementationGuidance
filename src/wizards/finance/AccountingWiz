      el('div', { className: 'journal-details' }, [
        el('span', { text: `Type: ${config.type}` }),
        el('span', { text: `Default: ${config.defaultAccount}` }),
        config.note ? el('small', { text: config.note }) : null
      ])
    ]);
  }

  async onApply() {
    const rollback = new RollbackEngine({ client: this.odooClient });
    
    // Verify confirmation checkbox
    if (!this.getField('accounting_confirm')) {
      this.showError('You must confirm understanding of the accounting impact.');
      return;
    }

    try {
      rollback.beginTransaction('Accounting Setup');

      // Update company fiscal settings
      await rollback.execute('res.company', 'write', 1, {
        fiscalyear_last_month: parseInt(this.getField('fiscal_year_start')),
        account_sale_tax_id: this.getTaxId('sales'),
        account_purchase_tax_id: this.getTaxId('purchase')
      });

      // Install chart of accounts from template
      const chartTemplate = this.getField('chart_template');
      await this.installChartOfAccounts(chartTemplate, rollback);

      // Create custom accounts
      const customAccounts = this.getList('custom_accounts');
      for (const acc of customAccounts) {
        await rollback.execute('account.account', 'create', {
          code: acc.code,
          name: acc.name,
          account_type: this.mapAccountType(acc.type)
        });
      }

      // Configure taxes
      await this.configureTaxes(rollback);

      // Set inventory valuation method on product categories
      await this.configureInventoryValuation(rollback);

      // Create/update journals
      await this.configureJournals(rollback);

      rollback.commit();
      this.showSuccess('Accounting setup complete!');
      this.navigateToNextWizard('GoLiveWizard');

    } catch (error) {
      await rollback.rollback();
      this.showError('Accounting setup failed: ' + error.message);
    }
  }

