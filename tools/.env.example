# Odoo Connection Settings
ODOO_BASE_URL=https://your-instance.odoo.com
ODOO_DATABASE=your_database
ODOO_USERNAME=your@email.com
ODOO_PASSWORD=your_password

# Import Settings
BATCH_SIZE=100
DRY_RUN=false
SKIP_ERRORS=true
VERBOSE=true

# Feature Toggles
IMPORT_CUSTOMERS=true
IMPORT_PRODUCTS=true
IMPORT_PRICELISTS=true
IMPORT_BOMS=true

# Data Files (relative to project root or absolute paths)
CUSTOMERS_FILE=./data/customers.xlsx
PRODUCTS_FILE=./data/products.xlsx
PRICELISTS_FILE=./data/pricelists.xlsx
BOMS_FILE=./data/boms.xls

# Output
OUTPUT_DIR=./output
LOG_LEVEL=info