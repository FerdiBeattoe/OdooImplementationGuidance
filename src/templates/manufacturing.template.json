{
  "name": "Manufacturing",
  "slug": "manufacturing",
  "description": "Complete manufacturing setup with BOMs, work centers, quality control, and production planning",
  "icon": "factory",
  "category": "operations",
  "odooVersion": "19.0",
  "modules": {
    "required": [
      "mrp",
      "quality_control",
      "maintenance",
      "stock"
    ],
    "recommended": [
      "mrp_repair",
      "quality_mrp",
      "maintenance_enterprise",
      "planning"
    ],
    "optional": [
      "plm",
      " subcontracting",
      "yield"
    ]
  },
  "dependencies": {
    "after": ["foundation", "users", "master_data"],
    "before": ["finance"]
  },
  "checkpoints": [
    {
      "id": "mfg_work_centers",
      "name": "Work Centers Configuration",
      "description": "Define work centers with capacity and efficiency rates",
      "required": true,
      "validation": {
        "model": "mrp.workcenter",
        "condition": "count > 0"
      }
    },
    {
      "id": "mfg_boms",
      "name": "Bill of Materials",
      "description": "Create BOMs for key products",
      "required": true,
      "validation": {
        "model": "mrp.bom",
        "condition": "count > 0"
      }
    },
    {
      "id": "mfg_routings",
      "name": "Production Routings",
      "description": "Define routing operations and sequence",
      "required": false,
      "validation": {
        "model": "mrp.routing",
        "condition": "count >= 0"
      }
    },
    {
      "id": "mfg_quality_points",
      "name": "Quality Control Points",
      "description": "Configure quality checkpoints for production",
      "required": true,
      "validation": {
        "model": "quality.point",
        "condition": "count > 0"
      }
    },
    {
      "id": "mfg_maintenance",
      "name": "Equipment & Maintenance",
      "description": "Register production equipment for maintenance",
      "required": false,
      "validation": {
        "model": "maintenance.equipment",
        "condition": "count >= 0"
      }
    }
  ],
  "defaultData": {
    "warehouses": [
      {
        "name": "Manufacturing Plant",
        "code": "MFG",
        "is_manufacturing_location": true,
        "company_type": "manufacturing"
      }
    ],
    "locations": [
      {
        "name": "Raw Materials",
        "usage": "supplier"
      },
      {
        "name": "Production",
        "usage": "production"
      },
      {
        "name": "Finished Goods",
        "usage": "internal"
      }
    ],
    "uom_categories": [
      {
        "name": "Manufacturing",
        "uoms": ["Unit", "Hour", "Minute", " kilogram", " Meter"]
      }
    ]
  },
  "workflow": {
    "procurement": "manufacture",
    "inventory_method": " fifo",
    "valuation": "real_time"
  },
  "settings": {
    "manufacture_lead": 7,
    "allow_routing": true,
    "allow_workorders": true,
    "quality_control_at_receive": true,
    "quality_control_at_produce": true
  }
}
