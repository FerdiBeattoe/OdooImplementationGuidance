          { id: 'project', name: 'Projects', description: 'Case management' }
        ]}
      ]
    };
    
    return moduleSets[this.data.industry] || moduleSets.services;
  }
  
  async createDatabase() {
    // This would integrate with OdooOnlineAPI or OnPremiseInstaller
    console.log('Creating database with settings:', this.data);
    
    // Show loading state
