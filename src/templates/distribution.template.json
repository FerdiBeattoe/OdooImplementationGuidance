{
  "name": "Distribution",
  "slug": "distribution",
  "description": "Multi-warehouse management, dropshipping, and advanced logistics",
  "icon": "truck",
  "category": "operations",
  "odooVersion": "19.0",
  "modules": {
    "required": [
      "stock",
      "purchase"
    ],
    "recommended": [
      "stock_dropshipping",
      "stock_landed_costs",
      "stock_picking_batch",
      "delivery"
    ],
    "optional": [
      "stock_rma",
      "stock_barcode",
      "stock_sms",
      "delivery_mondial_relay"
    ]
  },
  "dependencies": {
    "after": ["foundation", "users", "master_data"],
    "before": ["finance"]
  },
  "checkpoints": [
    {
      "id": "warehouse_setup",
      "name": "Warehouse Configuration",
      "description": "Configure warehouse locations and types",
      "required": true,
      "validation": {
        "model": "stock.warehouse",
        "condition": "count > 0"
      }
    },
    {
      "id": "routes_configured",
      "name": "Logistics Routes",
      "description": "Set up procurement and fulfillment routes",
      "required": true,
      "validation": {
        "model": "stock.route",
        "condition": "count > 0"
      }
    },
    {
      "id": "vendor_setup",
      "name": "Vendor Management",
      "description": "Configure suppliers and vendor lead times",
      "required": true,
      "validation": {
        "model": "res.partner",
        "condition": "supplier_count > 0"
      }
    },
    {
      "id": "dropship_config",
      "name": "Dropshipping Configuration",
      "description": "Set up dropshipping if applicable",
      "required": false,
      "validation": {
        "model": "stock.route",
        "condition": "dropship_route_exists"
      }
    }
  ],
  "defaultData": {
    "warehouses": [
      {
        "name": "Central Warehouse",
        "code": "WH",
        "is_drop_ship": false
      },
      {
        "name": "Regional Hub",
        "code": "RH",
        "is_drop_ship": false
      }
    ],
    "locations": [
      {
        "name": "Receiving Dock",
        "usage": "internal"
      },
      {
        "name": "Storage Zone A",
        "usage": "internal"
      },
      {
        "name": "Storage Zone B",
        "usage": "internal"
      },
      {
        "name": "Picking Zone",
        "usage": "internal"
      },
      {
        "name": "Shipping Dock",
        "usage": "internal"
      }
    ],
    "routes": [
      {
        "name": "Buy to Stock",
        "rule_type": "buy"
      },
      {
        "name": "Manufacturing to Stock",
        "rule_type": "manufacture"
      },
      {
        "name": "Drop Shipping",
        "rule_type": "dropship"
      }
    ]
  },
  "workflow": {
    "procurement": "buy",
    "inventory_method": "average",
    "valuation": "real_time"
  },
  "settings": {
    "use_existing_routes": true,
    "group_stock_by_location": true,
    "group_stock_by_category": false
  }
}
